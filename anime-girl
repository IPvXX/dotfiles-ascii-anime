def clear():
    os.system("clear")


def hide_cursor():
    sys.stdout.write("\033[?25l")
    sys.stdout.flush()


def show_cursor():
    sys.stdout.write("\033[?25h")
    sys.stdout.flush()


def wait_for_q():
    old_settings = termios.tcgetattr(sys.stdin)

    try:
        tty.setraw(sys.stdin.fileno())

        while True:
            key = sys.stdin.read(1)

            if key.lower() == "q":
                break

    finally:
        termios.tcsetattr(
            sys.stdin,
            termios.TCSADRAIN,
            old_settings
        )


def main():
    clear()

    # menu
    for number in artworks:
        print(number)

    choice = input("\n> ")

    if choice not in artworks:
        clear()
        return

    clear()

    hide_cursor()

    # remove the empty line at the start of the ASCII
    art = artworks[choice].lstrip("\n")

    print(art)
    sys.stdout.flush()

    wait_for_q()

    show_cursor()
    clear()


if __name__ == "__main__":
    main()
